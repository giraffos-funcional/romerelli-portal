{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "romerelli-portal (Next.js dev)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "romerelli-portal (Next.js prod)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 3000
    },
    {
      "name": "estimacion-preview",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "4567", "--directory", "/tmp/romerelli-preview"],
      "port": 4567
    }
  ]
}
